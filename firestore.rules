rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }
    
    function incoming() { 
      return request.resource.data; 
    }

    // PlaylistSource validate function
    function isValidPlaylistSource(data) {
      return data.id is string && data.id.size() <= 128
          && data.name is string && data.name.size() <= 128
          && data.type is string && data.type.size() <= 64
          && data.channelCount is int && data.channelCount >= 0
          && data.loaded is bool
          && data.active is bool;
    }

    // Channel validate function
    function isValidChannel(data) {
      return data.id is string && data.id.size() <= 128
          && data.name is string && data.name.size() <= 128
          && data.logo is string && data.logo.size() <= 512
          && data.url is string && data.url.size() <= 1024
          && data.category is string && data.category.size() <= 128
          && data.sourceId is string && data.sourceId.size() <= 128
          && data.online is bool;
    }

    // playlist_sources rules
    match /playlist_sources/{sourceId} {
      allow read: if true;
      allow create, update: if isValidId(sourceId) && isValidPlaylistSource(incoming());
      allow delete: if isValidId(sourceId);
    }

    // channels rules
    match /channels/{channelId} {
      allow read: if true;
      allow create, update: if isValidId(channelId) && isValidChannel(incoming());
      allow delete: if isValidId(channelId);
    }
  }
}
