rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Global Safety Net for other collections
    match /{document=**} {
      allow read, write: if false;
    }

    // playlist_sources rules - fully read/write open for seamless customized IPTV lists
    match /playlist_sources/{sourceId} {
      allow read, write: if true;
    }

    // channels rules - fully read/write open for high-reliability stream storage
    match /channels/{channelId} {
      allow read, write: if true;
    }
  }
}
